# Copy this file to .env and edit. The real .env is gitignored (never committed).
# These are read at startup by the CLI, the API, and the Drive example.

# Where the index lives
PAPERFINDER_DB=paperfinder.db

# Relationship graph DB (used by `paperfinder viz`)
PAPERFINDER_REL_DB=relationships.db

# Embedder: hashing (default, no deps, lexical) | st (bge-small, needs the `st` extra)
PAPERFINDER_EMBEDDER=hashing

# Vector backend: bruteforce (default) | sqlite-vec | qdrant
PAPERFINDER_VECTOR_STORE=bruteforce

# --- Qdrant (Stage 2 dense store) ---
# To use your Qdrant container instead of brute-force:
# PAPERFINDER_VECTOR_STORE=qdrant
# PAPERFINDER_QDRANT_URL=http://localhost:6533
# PAPERFINDER_QDRANT_COLLECTION=paperfinder_chunks
